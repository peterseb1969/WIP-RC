# WIP connection (used by @wip/proxy)
WIP_BASE_URL=https://localhost:8443
WIP_API_KEY=dev_master_key_for_testing

# MongoDB (direct connection for infra views)
MONGO_URI=mongodb://localhost:27017/

# NATS (direct connection for infra views)
NATS_URL=nats://localhost:4222

# NL Query (Claude API)
ANTHROPIC_API_KEY=sk-ant-...

# App
PORT=3010

# OIDC authentication (optional — enables user login via Dex)
# OIDC_ISSUER=http://localhost:5556/dex
# OIDC_CLIENT_ID=wip-apps
# OIDC_CLIENT_SECRET=wip-apps-secret
# SESSION_SECRET=change-me-to-a-random-string

# App-level access control (optional)
# ALLOWED_GROUPS=wip-admins
