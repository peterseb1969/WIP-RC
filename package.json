{
  "name": "wip-reactconsole",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "NODE_TLS_REJECT_UNAUTHORIZED=0 tsx watch server/index.ts",
    "build": "vite build",
    "start": "NODE_TLS_REJECT_UNAUTHORIZED=0 tsx server/index.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
