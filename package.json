    "@wip/proxy": "file:libs/wip-proxy-0.2.0.tgz",
    "@wip/react": "file:libs/wip-react-0.11.0.tgz",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^5.1.0",
    "express-session": "^1.18.1",
    "lucide-react": "^1.7.0",
    "mongodb": "^7.1.1",
    "nats": "^2.29.3",
    "openid-client": "^6.3.3",
    "papaparse": "^5.5.3",
    "react": "^19.1.0",
