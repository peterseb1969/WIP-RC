# Dockerfile.dev — development image for wip-deploy's --app-source override.
#
# Built by wip-deploy when invoked with:
#   wip-deploy install --target dev --app-source rc=/path/to/WIP-ReactConsole
#
# The entrypoint (docker-entrypoint-dev.sh, CASE-58 canonical pattern) handles:
#   - First-start populate of the named /app/node_modules volume.
#   - Re-install on host package-lock.json changes (hash-gated, self-healing).
#
# After install the CMD starts `npm run dev` — tsx watch (Express on 3011) +
# Vite (dev server + HMR on 5174), both with file watchers.
#
# CHOKIDAR_USEPOLLING: reliable file-change detection on macOS bind mounts.
# NODE_ENV=development: redundant with the deployer's env injection, kept as
# belt-and-suspenders for any path that runs the image without the renderer.
FROM node:20-alpine

WORKDIR /app

COPY docker-entrypoint-dev.sh /entrypoint-dev.sh
RUN chmod +x /entrypoint-dev.sh

ENV CHOKIDAR_USEPOLLING=1 \
    NODE_ENV=development \
    PORT=3011

# 3011 = Express (tsx watch), 5174 = Vite dev server + HMR WebSocket
EXPOSE 3011 5174

ENTRYPOINT ["/entrypoint-dev.sh"]
CMD ["npm", "run", "dev"]
