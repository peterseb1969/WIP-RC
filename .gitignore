node_modules/
dist/
.env
# Tarballs are ignored by default, with one deliberate exception (CASE-442):
# the versioned @wip/* tarballs package.json pins must be in-repo so a CI
# runner can `npm ci` + build images from git content alone. They are
# force-added (git add -f) rather than negated here, so stale versions never
# sneak in. On every lib refresh: git rm the old versioned .tgz, then
# git add -f the new ones the refresh shipped.
*.tgz
.DS_Store
.claude-context-pct

# Ephemeral per-session sentinel minted by /wip-setup + /wip-wake (CASE-389).
# The role marker (.session-role) IS tracked; the minted id is per-session.
.claude/.session-id
